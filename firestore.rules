rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────
    // セットアップ状態確認用（未認証でも読み取り可）
    // ログイン画面で「初回設定タブ」を表示するか判定するために使用
    // ─────────────────────────────────────────────────────────
    match /artifacts/{appId}/public/meta {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ─────────────────────────────────────────────────────────
    // 業者見積依頼
    // ・get（個別取得）: 誰でも可（UUID トークンで保護）
    // ・list（クエリ）: 誰でも可（業者フォームがトークンでクエリ必要なため）
    //   ※ トークンは crypto.randomUUID() の UUID のため列挙実質不可
    // ・create: 誰でも可（業者公開フォームから作成）
    // ・update（業者回答・完了報告・請求書）: 回答フィールドのみ許可
    //   ※ projectId / vendorId / token など核心フィールドの改ざんを防止
    // ・delete: 認証済みのみ
    // ─────────────────────────────────────────────────────────
    match /artifacts/{appId}/public/data/vendor_quote_requests/{docId} {
      allow get:    if true;
      allow list:   if true;
      allow create: if true;
      // 業者が変更可能なフィールドのみ許可（核心フィールドの改ざんを防止）
      allow update: if request.resource.data.diff(resource.data)
                      .affectedKeys()
                      .hasOnly([
                        'status', 'submittedAt',
                        'quoteType', 'totalAmount', 'items',
                        'vendorNote', 'pdfUrl',
                        'completionReport', 'vendorInvoice',
                        'updatedAt'
                      ]);
      allow delete: if request.auth != null;
    }

    // ─────────────────────────────────────────────────────────
    // 外部業者マスタ
    // ・read: 誰でも可（公開署名URLから確認するため）
    // ・write: 認証済みのみ
    // ・update（署名保存）: basicContract / updatedAt フィールドのみ非認証許可
    // ─────────────────────────────────────────────────────────
    match /artifacts/{appId}/public/data/vendors/{docId} {
      allow read:   if true;
      allow write:  if request.auth != null;
      // 業者署名ページ: basicContract フィールドのみ更新許可（他フィールドの改ざん防止）
      allow update: if request.resource.data.diff(resource.data)
                      .affectedKeys()
                      .hasOnly(['basicContract', 'updatedAt']);
    }

    // ─────────────────────────────────────────────────────────
    // 顧客向け契約書
    // ・read: 誰でも可（公開署名URLから確認するため）
    // ・write: 認証済みのみ
    // ・update（署名保存）: customerSignature / customerSignedAt のみ非認証許可
    // ─────────────────────────────────────────────────────────
    match /artifacts/{appId}/public/data/contracts/{docId} {
      allow read:   if true;
      allow write:  if request.auth != null;
      // 顧客署名ページ: 署名フィールドのみ更新許可（契約金額等の改ざん防止）
      allow update: if request.resource.data.diff(resource.data)
                      .affectedKeys()
                      .hasOnly(['customerSignature', 'customerSignedAt', 'updatedAt']);
    }

    // ─────────────────────────────────────────────────────────
    // 通知コレクション
    // ・create: 誰でも可（業者公開フォームからの通知作成）
    //   ※ notifiedUserIds・type のフィールド制限でスパム通知を軽減
    // ・read / update（既読）: 認証済みユーザーのみ
    // ─────────────────────────────────────────────────────────
    match /artifacts/{appId}/public/data/notifications/{docId} {
      allow create: if request.resource.data.keys().hasAll(['type', 'title', 'body'])
                    && request.resource.data.type is string
                    && request.resource.data.title is string
                    && request.resource.data.body.size() <= 500;
      allow read, update: if request.auth != null;
    }

    // ─────────────────────────────────────────────────────────
    // アプリデータ共通パス
    // artifacts/{appId}/public/data/{collection}/{docId}
    // ─────────────────────────────────────────────────────────
    match /artifacts/{appId}/public/data/{collection}/{docId} {

      // 認証済みユーザーは全データ読み取り可（一覧取得も含む）
      allow read: if request.auth != null;

      // ── users コレクション以外 ──────────────────────────────
      // 認証済みユーザーは作成・更新・削除可
      allow write: if request.auth != null && collection != 'users';

      // ── users コレクション ──────────────────────────────────
      // 【作成】
      //   - 自分のドキュメントは作成可（初回セットアップ・既存ユーザー登録）
      //   - 管理者は他ユーザーのドキュメントも作成可
      allow create: if request.auth != null
        && (docId == request.auth.uid || isAdmin(appId));

      // 【更新・削除】管理者のみ可
      allow update, delete: if request.auth != null && isAdmin(appId);
    }

    // ─────────────────────────────────────────────────────────
    // 管理者判定ヘルパー関数
    // ─────────────────────────────────────────────────────────
    function isAdmin(appId) {
      let userDoc = /databases/$(database)/documents/artifacts/$(appId)/public/data/users/$(request.auth.uid);
      return exists(userDoc) && get(userDoc).data.role == 'admin';
    }
  }
}
