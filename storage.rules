rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─────────────────────────────────────────────────────────
    // 業者見積PDF
    // ・write: 非認証可（業者が回答PDFをアップロード）、10MB/PDF限定
    // ・read:  認証済みのみ（URLを知っていても未認証では取得不可）
    // ─────────────────────────────────────────────────────────
    match /vendor-quotes/{requestId}/{filename} {
      allow write: if request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
      allow read: if request.auth != null;
    }

    // ─────────────────────────────────────────────────────────
    // 工事完了報告書（写真・PDF）
    // ・write: 非認証可（業者がアップロード）、8MB/画像orPDF限定
    // ・read:  認証済みのみ
    // ─────────────────────────────────────────────────────────
    match /completion-reports/{requestId}/{filename} {
      allow write: if request.resource.size < 8 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf');
      allow read: if request.auth != null;
    }

    // ─────────────────────────────────────────────────────────
    // 業者請求書（写真・PDF）
    // ・write: 非認証可（業者がアップロード）、8MB/画像orPDF限定
    // ・read:  認証済みのみ
    // ─────────────────────────────────────────────────────────
    match /vendor-invoices/{requestId}/{filename} {
      allow write: if request.resource.size < 8 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf');
      allow read: if request.auth != null;
    }

    // ─────────────────────────────────────────────────────────
    // アプリ配下のストレージ
    // ─────────────────────────────────────────────────────────
    match /artifacts/{appId}/{allPaths=**} {

      // 認証済みユーザーは読み取り可
      allow read: if request.auth != null;

      // 認証済みユーザーは画像・PDFファイルをアップロード可（10MB 上限）
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf');
    }
  }
}
