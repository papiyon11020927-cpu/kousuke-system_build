rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─────────────────────────────────────────────────────────
    // 業者見積PDF（認証不要・公開アップロード）
    // ─────────────────────────────────────────────────────────
    match /vendor-quotes/{requestId}/{filename} {
      allow write: if request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
      allow read: if true;
    }

    // ─────────────────────────────────────────────────────────
    // 工事完了報告書（写真・PDF）— 業者は非認証でアップロード可
    // ─────────────────────────────────────────────────────────
    match /completion-reports/{requestId}/{filename} {
      // 8MB 以内の画像 or PDF のみ許可
      allow write: if request.resource.size < 8 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf');
      allow read: if true;
    }

    // ─────────────────────────────────────────────────────────
    // アプリ配下のストレージ
    // ─────────────────────────────────────────────────────────
    match /artifacts/{appId}/{allPaths=**} {

      // 認証済みユーザーは読み取り可
      allow read: if request.auth != null;

      // 認証済みユーザーは画像・PDFファイルをアップロード可（10MB 上限）
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf');
    }
  }
}
